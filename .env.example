# EOF Digital Library - Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/eof_library

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...  # $5/month membership price

# Griot AI Integration
GRIOT_API_URL=http://localhost:3001
GRIOT_API_KEY=your-griot-api-key
GRIOT_FRONTEND_URL=http://localhost:5173

# Frontend
FRONTEND_URL=http://localhost:5174

# Server
PORT=3002
NODE_ENV=development
