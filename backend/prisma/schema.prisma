// EOF Digital Library - Database Schema
// 14 Tables for complete library management
// Using SQLite for local development

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =====================================
// USER & AUTH
// =====================================

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  displayName       String
  avatar            String?
  role              String    @default("READER") // READER, CREATOR, ADMIN, SUPER_ADMIN
  emailVerified     Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?

  // Relations
  membership        Membership?
  creatorProfile    CreatorProfile?
  orders            Order[]
  readingSessions   ReadingSession[]
  adaptationPrefs   AdaptationPreference[]
  adaptationReqs    AdaptationRequest[]
  legalAcceptances  LegalAcceptance[]
  bookshelves       Bookshelf[]

  @@index([email])
  @@index([role])
}

// =====================================
// MEMBERSHIP & BILLING
// =====================================

model Membership {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tier                String   @default("FREE") // FREE, MEMBER, CREATOR
  status              String   @default("ACTIVE") // ACTIVE, PAST_DUE, CANCELED, EXPIRED

  stripeCustomerId    String?  @unique
  stripeSubscriptionId String? @unique

  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean  @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([stripeCustomerId])
  @@index([status])
}

// =====================================
// CREATOR PROFILES
// =====================================

model CreatorProfile {
  id                    String    @id @default(uuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName           String
  bio                   String?
  website               String?
  socialLinks           String?   // JSON string

  // Payout info
  payoutMethod          String?
  payoutAccountId       String?

  // Stats
  totalEarnings         Float     @default(0)
  totalSales            Int       @default(0)

  // Verification
  verified              Boolean   @default(false)
  verifiedAt            DateTime?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  products              Product[]
  externalStores        ExternalStoreConnection[]

  @@index([verified])
}

// =====================================
// PRODUCTS (Books, Content)
// =====================================

model Product {
  id                    String          @id @default(uuid())
  creatorId             String?
  creator               CreatorProfile? @relation(fields: [creatorId], references: [id], onDelete: SetNull)

  title                 String
  author                String
  slug                  String          @unique
  description           String?
  coverImage            String?

  // Pricing
  price                 Float           @default(0)
  currency              String          @default("USD")
  isFree                Boolean         @default(false)
  memberIncluded        Boolean         @default(true)

  // Content type
  type                  String          @default("EBOOK") // EBOOK, AUDIOBOOK, etc
  format                String?
  pageCount             Int?
  wordCount             Int?

  // Source
  source                String          @default("ORIGINAL") // ORIGINAL, GUTENBERG, PUBLIC_DOMAIN, LICENSED
  gutenbergId           String?
  externalUrl           String?

  // Status
  status                String          @default("DRAFT") // DRAFT, PENDING_REVIEW, PUBLISHED, ARCHIVED, REJECTED
  publishedAt           DateTime?

  // Adaptation rights
  adaptationAllowed     Boolean         @default(false)
  adaptationTerms       String?
  adaptationFee         Float?

  // Stats
  viewCount             Int             @default(0)
  downloadCount         Int             @default(0)
  averageRating         Float?
  ratingCount           Int             @default(0)

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  // Relations
  genres                ProductGenre[]
  files                 ProductFile[]
  orders                Order[]
  readingSessions       ReadingSession[]
  adaptationRequests    AdaptationRequest[]
  bookshelfItems        BookshelfItem[]

  @@index([slug])
  @@index([creatorId])
  @@index([status])
  @@index([source])
  @@index([adaptationAllowed])
}

// =====================================
// GENRES
// =====================================

model Genre {
  id          String         @id @default(uuid())
  name        String         @unique
  slug        String         @unique
  description String?
  icon        String?
  parentId    String?
  parent      Genre?         @relation("GenreHierarchy", fields: [parentId], references: [id])
  children    Genre[]        @relation("GenreHierarchy")

  products    ProductGenre[]

  @@index([slug])
  @@index([parentId])
}

model ProductGenre {
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  genreId     String
  genre       Genre    @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([productId, genreId])
}

// =====================================
// PRODUCT FILES
// =====================================

model ProductFile {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  filename    String
  fileUrl     String
  fileSize    Int
  mimeType    String
  format      String

  isPrimary   Boolean   @default(false)

  createdAt   DateTime  @default(now())

  @@index([productId])
  @@index([format])
}

// =====================================
// EXTERNAL STORE CONNECTIONS
// =====================================

model ExternalStoreConnection {
  id            String          @id @default(uuid())
  creatorId     String
  creator       CreatorProfile  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  storeName     String
  storeUrl      String?
  apiKey        String?
  apiSecret     String?

  isActive      Boolean         @default(true)
  lastSyncAt    DateTime?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([creatorId, storeName])
  @@index([storeName])
}

// =====================================
// ORDERS & PURCHASES
// =====================================

model Order {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId           String
  product             Product  @relation(fields: [productId], references: [id])

  amount              Float
  currency            String   @default("USD")
  status              String   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED

  stripePaymentId     String?  @unique
  stripeInvoiceId     String?

  // Creator payout tracking
  creatorAmount       Float?
  platformFee         Float?
  payoutStatus        String   @default("PENDING") // PENDING, PROCESSING, PAID, FAILED
  paidOutAt           DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([productId])
  @@index([status])
  @@index([payoutStatus])
}

// =====================================
// READING SESSIONS
// =====================================

model ReadingSession {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId       String
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Progress tracking
  currentPage     Int       @default(0)
  totalPages      Int?
  percentComplete Float     @default(0)

  // Time tracking
  totalReadTime   Int       @default(0)
  lastReadAt      DateTime  @default(now())

  // Bookmarks and notes (JSON strings)
  bookmarks       String?
  highlights      String?

  startedAt       DateTime  @default(now())
  finishedAt      DateTime?

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@index([lastReadAt])
}

// =====================================
// ADAPTATION (Griot AI Integration)
// =====================================

model AdaptationPreference {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  preferredFormat String
  targetAudience  String?
  tonePreference  String?

  griotProjectId  String?
  autoSync        Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
}

model AdaptationRequest {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId       String
  product         Product   @relation(fields: [productId], references: [id])

  targetFormat    String
  notes           String?

  status          String    @default("PENDING") // PENDING, APPROVED, DENIED, IN_PROGRESS, COMPLETED, CANCELLED
  reviewedAt      DateTime?
  reviewedBy      String?
  reviewNotes     String?

  feeAmount       Float?
  feePaid         Boolean   @default(false)
  paidAt          DateTime?

  griotProjectId  String?
  griotExportUrl  String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([productId])
  @@index([status])
}

// =====================================
// LEGAL & COMPLIANCE
// =====================================

model LegalAcceptance {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  documentType    String
  documentVersion String

  acceptedAt      DateTime  @default(now())
  ipAddress       String?
  userAgent       String?

  @@unique([userId, documentType])
  @@index([documentType])
}

// =====================================
// ADMIN
// =====================================

model AdminReview {
  id            String    @id @default(uuid())

  entityType    String
  entityId      String

  reviewerId    String
  action        String    // APPROVED, REJECTED, FLAGGED, UNFLAGGED
  notes         String?

  createdAt     DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([reviewerId])
}

// =====================================
// BOOKSHELVES
// =====================================

model Bookshelf {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  isPublic    Boolean         @default(false)
  isDefault   Boolean         @default(false)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  items       BookshelfItem[]

  @@index([userId])
  @@index([isPublic])
}

model BookshelfItem {
  id          String    @id @default(uuid())
  bookshelfId String
  bookshelf   Bookshelf @relation(fields: [bookshelfId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  addedAt     DateTime  @default(now())
  sortOrder   Int       @default(0)

  @@unique([bookshelfId, productId])
  @@index([bookshelfId])
}
